# ===========================================================================
# Accessly — example environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your local environment.
# `.env` is git-ignored and must never be committed. No real secrets here.
# ===========================================================================

# --- Runtime ---
ASPNETCORE_ENVIRONMENT=Development

# --- SQL Server (container) ---
# Strong dev-only password (changeme). Used by the sqlserver container and the API connection string.
MSSQL_SA_PASSWORD=Your_strong_Passw0rd!
ConnectionStrings__Default=Server=sqlserver,1433;Database=Accessly;User Id=sa;Password=Your_strong_Passw0rd!;TrustServerCertificate=True;Encrypt=False

# --- JWT authentication ---
# Dev-only signing key. Generate a long random value for any shared environment.
Jwt__Issuer=accessly
Jwt__Audience=accessly-clients
Jwt__SigningKey=dev-only-change-me-please-use-a-long-random-string-32+chars
Jwt__AccessTokenMinutes=120

# --- Redis ---
Redis__Connection=redis:6379
Redis__Enabled=true

# --- RabbitMQ ---
RabbitMq__Enabled=true
RabbitMq__Host=rabbitmq
RabbitMq__Port=5672
RabbitMq__Username=guest
RabbitMq__Password=guest
RabbitMq__Exchange=accessly.events

# --- Hangfire ---
Hangfire__DashboardEnabled=true

# --- Notifications / email (fictional by default) ---
Email__Provider=Fake
Email__FromAddress=no-reply@accessly.local
Email__FromName=Accessly

# --- AI assistant (disabled by default; Fake provider is deterministic) ---
Ai__Enabled=true
Ai__Provider=Fake
# The following are only used when Ai__Provider=OpenAiCompatible (optional, off by default).
Ai__BaseUrl=
Ai__ApiKey=
Ai__Model=

# --- CORS (comma-separated origins for the Angular app) ---
Cors__AllowedOrigins=http://localhost:4200,http://localhost:8080

# --- Demo data seeding ---
Seed__Enabled=true

# --- Frontend (Angular) ---
NG_APP_API_BASE_URL=http://localhost:8080

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
